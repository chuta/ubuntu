# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AWS S3 — document & knowledge storage (Week 5)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=ubuntu-growthos-prod
# Alias also supported: AWS_S3_BUCKET=ubuntu-growthos-prod
AWS_REGION=eu-west-1

# Anthropic — AI document drafting (Week 5)
# Full key from console.anthropic.com (starts with sk-ant-api03-…)
ANTHROPIC_API_KEY=

# Google Calendar — import only (Week 6)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/calendar/callback

# App URL (for auth redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Session timeouts (optional — defaults: 30 min idle, 48 h max, 5 min prompt grace)
# NEXT_PUBLIC_SESSION_IDLE_MINUTES=30
# NEXT_PUBLIC_SESSION_MAX_HOURS=48
# NEXT_PUBLIC_SESSION_PROMPT_GRACE_MINUTES=5
